# This file is persisted on /mnt/persistent-data/nginx/configs/minecraft-ssl
# and survives instance rebuilds. Customizations made here will persist.
# To apply changes after editing on the instance:
#   sudo systemctl reload nginx

server {
    listen 80;
    listen [::]:80;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    # Update these paths to your domain (e.g., /etc/letsencrypt/live/your-domain.com/)
    ssl_certificate /etc/letsencrypt/live/bolanderfamily.net/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/bolanderfamily.net/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;
    add_header Strict-Transport-Security "max-age=31536000" always;
    root /mnt/persistent-data/nginx/www;
    
    # Main site
    location / {
        try_files $uri $uri/ =404;
    }

    location /bluemap/ {
    proxy_pass http://127.0.0.1:8100/;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }   

    location ~ /\. {
        deny all;
    }
}